font-family = "Iosevka Big 27"
font-style = "Retina"
font-size = 18

theme = dark:Gruvbox Material Dark,light:Gruvbox Material Light

background-opacity = 1
background-blur = true
window-padding-y = 0
window-padding-x = 0
window-padding-balance = true
window-padding-color = extend
window-decoration = false

adjust-cursor-thickness = 100%
custom-shader = shaders/cursor_smear.glsl

keybind = alt+p=toggle_command_palette
shell-integration-features = "ssh-terminfo,ssh-env,sudo"
